<Window x:Class="WrongThemeDictionary.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WrongThemeDictionary"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="RedCustomStyle" TargetType="{x:Type local:CustomControl}" BasedOn="{StaticResource {x:Type local:CustomControl}}">
            <Setter Property="Background" Value="Red" />
        </Style>
    </Window.Resources>

    <StackPanel Name="Panel" Orientation="Vertical">
        <Button Click="Button_Click">Click to Crash</Button>
        
        <!-- This control will look for the implicit style for CustomControl, which is a deferred resource and cached into SystemResources -->
        <local:CustomContainer x:Name="SingleColorContainer" ItemContainerStyle="{StaticResource RedCustomStyle}" />

        <local:CustomContainer x:Name="CustomColorContainer">
            <local:CustomContainer.ItemContainerStyle>
                <!-- This style has no BasedOn so the style lookup will fail -->
                <Style TargetType="{x:Type local:CustomControl}">
                    <Setter Property="Background" Value="{Binding}" />
                </Style>
            </local:CustomContainer.ItemContainerStyle>
        </local:CustomContainer>
    </StackPanel>
</Window>
